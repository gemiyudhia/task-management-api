generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String

  role Role @default(USER)

  hashedRefreshToken String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
